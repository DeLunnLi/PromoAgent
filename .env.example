# PromoAgent 环境变量
# 复制为 .env 后填入真实密钥，切勿提交到 Git
# 只需配置【一个】LLM 提供商即可

# ══════════════════════════════════════════════════════
# 选项 1：OpenAI
# ══════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-your-key
# PROMOAGENT_MODEL=gpt-4o-mini

# ══════════════════════════════════════════════════════
# 选项 2：Anthropic Claude（自动检测 ANTHROPIC_API_KEY）
# ══════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-your-key
# PROMOAGENT_MODEL=claude-haiku-4-5

# ══════════════════════════════════════════════════════
# 选项 3：Google Gemini（自动检测 GOOGLE_API_KEY 或 GEMINI_API_KEY）
# ══════════════════════════════════════════════════════
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_API_KEY=your-gemini-api-key
# PROMOAGENT_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════
# 选项 4：Ollama（本地运行，免费）
# 先运行：ollama serve && ollama pull llama3.2
# ══════════════════════════════════════════════════════
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_HOST=http://localhost:11434
# PROMOAGENT_MODEL=llama3.2

# ══════════════════════════════════════════════════════
# 选项 5：ModelScope（推荐：文本 + 图片生成共用同一 Token）
# 获取地址：https://modelscope.cn/my/myaccesstoken
# ══════════════════════════════════════════════════════
PROMOAGENT_MODELSCOPE_API_KEY=ms-your-token
PROMOAGENT_BASE_URL=https://api-inference.modelscope.cn/v1
PROMOAGENT_MODEL=Qwen/Qwen3.5-397B-A17B

# ══════════════════════════════════════════════════════
# 选项 6：任意 OpenAI 兼容接口
# ══════════════════════════════════════════════════════
# PROMOAGENT_API_KEY=your-key
# PROMOAGENT_BASE_URL=https://your-api.example.com/v1
# PROMOAGENT_MODEL=your-model-name

# ── 提供商显式指定（可选，覆盖自动检测）──────────────
# PROMOAGENT_PROVIDER=openai|anthropic|gemini|ollama|modelscope

# ── 通用参数 ──────────────────────────────────────────
PROMOAGENT_MAX_TOKENS=4096
PROMOAGENT_TEMPERATURE=0.7
PROMOAGENT_TIMEOUT_MS=120000

# ── 缓存 ─────────────────────────────────────────────
# PROMOAGENT_CACHE_DIR=~/.cache/promoagent    # 自定义缓存目录
# PROMOAGENT_CACHE_TTL=3600                    # 缓存有效期（秒）
# PROMOAGENT_CACHE_DISABLED=0                  # 1=禁用缓存

# ── 日志 / 调试 ──────────────────────────────────────
# PROMOAGENT_LOG_LEVEL=INFO                    # INFO|WARNING|ERROR
# PROMOAGENT_LOG_FORMAT=text                   # text|json
# PROMOAGENT_DEBUG=0                           # 1=打印完整异常栈

# ── 示例搜索增强（research 阶段搜参考广告）────────────
# Tavily — 关键词搜索，国内外内容均可（https://tavily.com，有免费额度）
# TAVILY_API_KEY=tvly-your-key

# Exa   — 语义 / 神经搜索，尤其适合 Show HN / Product Hunt / 英文内容
#         （https://exa.ai，每月 1000 次免费搜索）
# EXA_API_KEY=exa-your-key

# ── 网页内容抓取（analyze 非 GitHub URL 时使用）────────
# Firecrawl — 将任意网站/HuggingFace/npm 页面转为 Markdown 供证据提取
#             免费层无需 API Key；高级功能（crawl/agent）需要付费 Key
#             （https://firecrawl.dev）
# FIRECRAWL_API_KEY=fc-your-key

# ── GitHub API（远程仓库扫描时提高 rate limit）────────
# GITHUB_TOKEN=ghp_your-token
# PROMOAGENT_GITHUB_TOKEN=ghp_your-token       # 别名（GITHUB_TOKEN 的前缀版）

# ── PDF 提取（论文分析）────────────────────────────────
# 默认：正则回退（零依赖）
# 推荐：安装 pypdf 后自动启用文本提取（pip install 'promoagent[pdf]'）
#
# 扫描版 PDF（图片型论文）需要 OCR，三种模式：
#   PROMOAGENT_PDF_OCR=tesseract  — pytesseract（需本地安装 Tesseract 二进制）
#   PROMOAGENT_PDF_OCR=true       — 同上（向后兼容）
#   PROMOAGENT_PDF_OCR=ai         — 调用已配置的 AI 视觉模型（GPT-4o / Claude / Gemini）
#
# pip install 'promoagent[ocr]'  启用 OCR（pypdf + pypdfium2 + Pillow）
# PROMOAGENT_PDF_OCR=ai
# PROMOAGENT_PDF_OCR_LANG=chi_sim+eng    # 仅 tesseract 模式
# PROMOAGENT_PDF_OCR_MAX_PAGES=12
# PROMOAGENT_PDF_MAX_PAGES=60            # pypdf 最多读取页数（默认 60）

# ── 创作引导（可选，注入 AI 推广 prompt）──────────────
# PROMOAGENT_PROMO_BRIEF=小红书偏踩坑日记体，知乎 70% 方法论
# PROMOAGENT_PROMO_BRIEF_FILE=./promo-brief.md

# ── 图片生成（promoagent draft --image）──────────────
# 默认：ModelScope Qwen-Image 文生图（与 PROMOAGENT_MODELSCOPE_API_KEY 共用）
PROMOAGENT_IMAGE_MODEL=Qwen/Qwen-Image
PROMOAGENT_IMAGE_STYLE=poster
# 图片专用 OpenAI 兼容接口（不会影响 PROMOAGENT_API_KEY/PROMOAGENT_MODEL 文案模型）
# PROMOAGENT_IMAGE_API_KEY=sk-your-image-key
# PROMOAGENT_IMAGE_BASE_URL=https://api.openai.com/v1
# PROMOAGENT_IMAGE_MODEL=gpt-image-2
# PROMOAGENT_IMAGE_QUALITY=high
# PROMOAGENT_IMAGE_PLATFORMS=xhs,wechat,twitter,linkedin
# PROMOAGENT_IMAGE_VARIANTS=2
# 可选创意 skill：auto | ad-cover | xhs-lifestyle | food-local | product-hero | event-poster | b2b-saas | research-editorial | service-trust
# PROMOAGENT_IMAGE_SKILL=auto
# 可选风格：poster（默认）| minimal | terminal | vibrant
# 图片格式：portrait(3:4) | square(1:1) | landscape(16:9)，留空按平台自动
# PROMOAGENT_IMAGE_FORMAT=portrait
PROMOAGENT_IMAGE_POLL_MS=5000
PROMOAGENT_IMAGE_TIMEOUT_MS=300000

# ── 本地 Gradio 文生图（可选）──────────────────────────
# PROMOAGENT_IMAGE_PROVIDER=gradio
# PROMOAGENT_GRADIO_URL=http://127.0.0.1:7860
# PROMOAGENT_GRADIO_API=generate_image
# PROMOAGENT_GRADIO_PROMPT_EXTEND=true
# PROMOAGENT_GRADIO_WIDTH=2688
# PROMOAGENT_GRADIO_HEIGHT=1536
# PROMOAGENT_GRADIO_WECHAT_SIZE=1536
# PROMOAGENT_GRADIO_POLL_MS=2000
# PROMOAGENT_GRADIO_TIMEOUT_MS=600000

# ── ModelScope 图像编辑（可选，需参考图 image_url）──
# PROMOAGENT_IMAGE_MODEL=FireRedTeam/FireRed-Image-Edit-1.1
# PROMOAGENT_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2511

# ══════════════════════════════════════════════════════
# 平台发布凭据（promoagent publish）
# ══════════════════════════════════════════════════════

# Telegram（最简单，@BotFather 创建 Bot 获取 Token）
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=@your_channel  或  -1001234567890

# Bluesky（Settings → App Passwords 创建密码）
# BLUESKY_HANDLE=yourname.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Twitter/X（需申请 Developer 权限 → 创建 App → User Access Token）
# TWITTER_ACCESS_TOKEN=your-oauth2-user-access-token

# LinkedIn（创建 App → OAuth 2.0 Access Token，需 w_member_social scope）
# LINKEDIN_ACCESS_TOKEN=your-access-token
# LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_PROFILE_ID

# Reddit（reddit.com/prefs/apps 创建 script 类型 App）
# REDDIT_CLIENT_ID=your-client-id
# REDDIT_CLIENT_SECRET=your-client-secret
# REDDIT_USERNAME=your-reddit-username
# REDDIT_PASSWORD=your-reddit-password
# REDDIT_SUBREDDIT=programming  # 目标子版块

# 微博（open.weibo.com 注册应用，获取 OAuth2 Access Token）
# WEIBO_ACCESS_TOKEN=your-weibo-access-token
