# Source2Launch 环境变量
# 复制为 .env 后填入真实密钥，切勿提交到 Git
# 只需配置【一个】LLM 提供商即可

# ══════════════════════════════════════════════════════
# 选项 1：OpenAI
# ══════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-your-key
# SOURCE2LAUNCH_MODEL=gpt-4o-mini

# ══════════════════════════════════════════════════════
# 选项 2：Anthropic Claude（自动检测 ANTHROPIC_API_KEY）
# ══════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-your-key
# SOURCE2LAUNCH_MODEL=claude-haiku-4-5

# ══════════════════════════════════════════════════════
# 选项 3：Google Gemini（自动检测 GOOGLE_API_KEY）
# ══════════════════════════════════════════════════════
# GOOGLE_API_KEY=your-google-api-key
# SOURCE2LAUNCH_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════
# 选项 4：Ollama（本地运行，免费）
# 先运行：ollama serve && ollama pull llama3.2
# ══════════════════════════════════════════════════════
# OLLAMA_BASE_URL=http://localhost:11434
# SOURCE2LAUNCH_MODEL=llama3.2

# ══════════════════════════════════════════════════════
# 选项 5：ModelScope（推荐：文本 + 图片生成共用同一 Token）
# 获取地址：https://modelscope.cn/my/myaccesstoken
# ══════════════════════════════════════════════════════
SOURCE2LAUNCH_MODELSCOPE_API_KEY=ms-your-token
SOURCE2LAUNCH_BASE_URL=https://api-inference.modelscope.cn/v1
SOURCE2LAUNCH_MODEL=Qwen/Qwen3.5-397B-A17B

# ══════════════════════════════════════════════════════
# 选项 6：任意 OpenAI 兼容接口
# ══════════════════════════════════════════════════════
# SOURCE2LAUNCH_API_KEY=your-key
# SOURCE2LAUNCH_BASE_URL=https://your-api.example.com/v1
# SOURCE2LAUNCH_MODEL=your-model-name

# ── 通用参数 ──────────────────────────────────────────
SOURCE2LAUNCH_STREAM=false
SOURCE2LAUNCH_MAX_TOKENS=4096
SOURCE2LAUNCH_TEMPERATURE=0.7
SOURCE2LAUNCH_TIMEOUT_MS=120000

# ── Agent 工具（推广文案：搜索 / 读证据 / 生图）──────
SOURCE2LAUNCH_AGENT_TOOLS=true
SOURCE2LAUNCH_AGENT_MAX_STEPS=8
SOURCE2LAUNCH_AGENT_TIMEOUT_MS=300000
# SOURCE2LAUNCH_AGENT_TOOL_LIST=web_search,fetch_page_text,read_project_summary,read_pdf_document,read_repo_evidence,generate_promo_image

# ── 大模型项目理解（--read-project / --optimize，默认启用）──
# 配置 SOURCE2LAUNCH_MODELSCOPE_API_KEY 后，--read-project 由大模型阅读并介绍项目
# 加 --local 可强制仅用本地 evidence 摘要
# SOURCE2LAUNCH_PDF_OCR=true
# SOURCE2LAUNCH_PDF_OCR_LANG=chi_sim+eng
# SOURCE2LAUNCH_PDF_OCR_MAX_PAGES=12

# ── 创作引导（可选，注入 AI 推广 prompt）──────────────
# SOURCE2LAUNCH_PROMO_BRIEF=小红书偏踩坑日记体，知乎 70% 方法论
# SOURCE2LAUNCH_PROMO_BRIEF_FILE=./promo-brief.md

# ── 图片生成（source2launch image / optimize 配图）────
# 默认：ModelScope Qwen-Image 文生图（无需参考图，与 SOURCE2LAUNCH_MODELSCOPE_API_KEY 共用）
SOURCE2LAUNCH_IMAGE_PROVIDER=modelscope
SOURCE2LAUNCH_IMAGE_MODEL=Qwen/Qwen-Image
SOURCE2LAUNCH_IMAGE_STYLE=poster
# 可选风格：poster（默认）| minimal | terminal | vibrant
SOURCE2LAUNCH_IMAGE_PROMPT_EXTEND=false
SOURCE2LAUNCH_IMAGE_WIDTH=1104
SOURCE2LAUNCH_IMAGE_HEIGHT=1472
SOURCE2LAUNCH_IMAGE_WECHAT_SIZE=1024
# 小红书默认：先生成 1:1 方形再扩展为 3:4，避免竖版直出手机 mockup
# SOURCE2LAUNCH_IMAGE_XHS_COMPOSE=false
# 封面文字：默认用 SVG 叠加（清晰中文，不由 AI 绘制）
# SOURCE2LAUNCH_IMAGE_TEXT_OVERLAY=false
# SOURCE2LAUNCH_IMAGE_TITLE=Source2Launch
# SOURCE2LAUNCH_IMAGE_SUBTITLE=项目/论文发布前，先让 AI 读懂证据
# SOURCE2LAUNCH_IMAGE_BADGES=AI 项目理解,内容审核,推广文案
# SOURCE2LAUNCH_IMAGE_SIZE=1248x1664
SOURCE2LAUNCH_IMAGE_POLL_MS=5000
SOURCE2LAUNCH_IMAGE_TIMEOUT_MS=300000

# ── 本地 Gradio 文生图（可选）──────────────────────────
# SOURCE2LAUNCH_IMAGE_PROVIDER=gradio
# SOURCE2LAUNCH_GRADIO_URL=http://127.0.0.1:7860
# SOURCE2LAUNCH_GRADIO_API=generate_image
# SOURCE2LAUNCH_GRADIO_PROMPT_EXTEND=true
# SOURCE2LAUNCH_GRADIO_WIDTH=2688
# SOURCE2LAUNCH_GRADIO_HEIGHT=1536
# SOURCE2LAUNCH_GRADIO_WECHAT_SIZE=1536
# SOURCE2LAUNCH_GRADIO_POLL_MS=2000
# SOURCE2LAUNCH_GRADIO_TIMEOUT_MS=600000

# ── ModelScope 图像编辑（可选，需参考图 image_url）──
# SOURCE2LAUNCH_IMAGE_MODEL=FireRedTeam/FireRed-Image-Edit-1.1
# SOURCE2LAUNCH_IMAGE_MODEL=Qwen/Qwen-Image-Edit-2511

# ── 其他 OpenAI 兼容服务（可选，替代 ModelScope）──────
# SOURCE2LAUNCH_API_KEY=sk-your-key
# SOURCE2LAUNCH_BASE_URL=https://api.openai.com/v1
# SOURCE2LAUNCH_MODEL=gpt-4.1-mini

# ── GitHub API（远程仓库扫描时提高 rate limit）────────
# GITHUB_TOKEN=ghp_your-token

# ══════════════════════════════════════════════════════
# 平台发布凭据（source2launch publish）
# ══════════════════════════════════════════════════════

# Telegram（最简单，@BotFather 创建 Bot 获取 Token）
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=@your_channel  或  -1001234567890

# Bluesky（Settings → App Passwords 创建密码）
# BLUESKY_HANDLE=yourname.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Twitter/X（需申请 Developer 权限 → 创建 App → User Access Token）
# TWITTER_ACCESS_TOKEN=your-oauth2-user-access-token

# LinkedIn（创建 App → OAuth 2.0 Access Token，需 w_member_social scope）
# LINKEDIN_ACCESS_TOKEN=your-access-token
# LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_PROFILE_ID

# Reddit（reddit.com/prefs/apps 创建 script 类型 App）
# REDDIT_CLIENT_ID=your-client-id
# REDDIT_CLIENT_SECRET=your-client-secret
# REDDIT_USERNAME=your-reddit-username
# REDDIT_PASSWORD=your-reddit-password
# REDDIT_SUBREDDIT=programming  # 目标子版块

# 微博（open.weibo.com 注册应用，获取 OAuth2 Access Token）
# WEIBO_ACCESS_TOKEN=your-weibo-access-token
