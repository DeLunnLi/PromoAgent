#!/usr/bin/env python3
import os
from pathlib import Path
import shutil
import subprocess
import sys

PACKAGE_ROOT = Path(__file__).resolve().parents[1]
if str(PACKAGE_ROOT) not in sys.path:
    sys.path.insert(0, str(PACKAGE_ROOT))

try:
    from promoagent.cli import main  # noqa: E402
except ModuleNotFoundError as exc:
    if exc.name == "rich" and not os.environ.get("PROMOAGENT_BIN_REEXEC"):
        candidates = [
            os.environ.get("PROMOAGENT_PYTHON"),
            shutil.which("python"),
            shutil.which("python3"),
        ]
        for candidate in candidates:
            if candidate and Path(candidate).resolve() != Path(sys.executable).resolve():
                env = {**os.environ, "PROMOAGENT_BIN_REEXEC": "1"}
                raise SystemExit(subprocess.call([candidate, __file__, *sys.argv[1:]], env=env))
    raise


if __name__ == "__main__":
    raise SystemExit(main())
